rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (student, teacher, headteacher, officer)
    //   - schoolId: string
    //   - grade: string
    //   - createdAt: timestamp
    //
    // Collection: schemesOfWork
    // Document ID: {schemeId}
    // Fields:
    //   - teacherId: string (required)
    //   - learningArea: string
    //   - grade: string
    //   - term: string
    //   - content: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'headteacher' || 
         (request.auth.token.email == "dgithinji331@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' ||
         (request.auth.token.email == "dgithinji331@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['student', 'teacher', 'headteacher', 'officer'];
    }

    function isValidScheme(data) {
      return data.keys().hasAll(['teacherId', 'learningArea', 'grade', 'term', 'content']) &&
             data.teacherId == request.auth.uid &&
             data.content is string && data.content.size() < 50000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /schemesOfWork/{schemeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidScheme(request.resource.data);
      allow update: if isAuthenticated() && resource.data.teacherId == request.auth.uid && isValidScheme(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.teacherId == request.auth.uid);
    }
  }
}
